{
  "name": "Anna's Analysis Environment",
  "build": {
    "dockerfile": "Dockerfile",
    "context": ".." 
  },
  "mounts": [
    "source=${localWorkspaceFolder}/data,target=/work/data,type=bind",
    "source=${localWorkspaceFolder}/results,target=/work/results,type=bind"
  ],
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-python.python", 
        "ms-toolsai.jupyter"
      ],
      "settings": {
        "python.defaultInterpreterPath": "/opt/conda/envs/msse-env/bin/python"
      }
    }
  },
  "postCreateCommand": "conda env create -f environment.yml || conda env update -f environment.yml",
  "remoteUser": "root",
  "workspaceFolder": "/work"
}